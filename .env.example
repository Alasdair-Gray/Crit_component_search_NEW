# Azure cloud LLM endpoint (OpenAI-compatible)
AZURE_LLM_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-deployment
AZURE_LLM_API_KEY=your-api-token-here
# Optional: deployment/model name (defaults to gpt-4 if not set)
# AZURE_LLM_MODEL=your-deployment-name
SEARCH_API_KEY=your-brave-search-key-here
SEARCH_PROVIDER=brave
FLASK_SECRET_KEY=change-this-in-production
LOG_LEVEL=INFO

# Webapp auth (required unless CCS_WEBAPP_INSECURE=true)
CCS_WEBAPP_USER=admin
CCS_WEBAPP_PASSWORD=change-me
# Set to true to run without auth (dev only; app refuses to start without credentials otherwise)
# CCS_WEBAPP_INSECURE=true
